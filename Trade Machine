local function findGui()

    local guiObj = playerGui:FindFirstChild("TradeLiveTrade")

    if not guiObj then return end

    local main = guiObj:FindFirstChild("TradeLiveTrade")

    if not main then return end

    local other = main:FindFirstChild("Other")

    if not other then return end

    readyFrame = other:FindFirstChild("Ready")
    readyButton = other:FindFirstChild("ReadyButton")
end

findGui()

local function click(button)

    if not button then return end
    if not button.Visible then return end
    if not button.Active then return end

    pcall(function()
        button:Activate()
    end)

    pcall(function()

        for _, c in ipairs(getconnections(button.Activated)) do
            c:Fire()
        end
    end)

    pcall(function()

        for _, c in ipairs(getconnections(button.MouseButton1Click)) do
            c:Fire()
        end
    end)
end

RunService.Heartbeat:Connect(function()

    forceHideSelectionGears()

    if not tradeUI.Visible and warningTemplate.Visible then
        warningTemplate.Visible = false
        confirmationUI.Enabled = false
        pendingPanel = nil

        resetHover(yesButton)
        resetHover(noButton)
    end

    checkAcceptState()

    local other = tradeUI:FindFirstChild("Other")

    if other then

        local timer = other:FindFirstChild("Timer")
        local ready = other:FindFirstChild("Ready")
        local readyButtonObj = other:FindFirstChild("ReadyButton")

        if timer and ready and readyButtonObj then

            local txt = readyButtonObj:FindFirstChild("Txt")

            if txt then

                if timer.Text == "⏰0.1s Left"
                    and txt.Text == "ACCEPT"
                    and ready.Visible then

                    if not temporaryAutoAccept then

                        temporaryAutoAccept = true
                        temporaryAcceptEnd = tick() + 5

                        autoAccept = true

                        updateToggle()
                    end
                end
            end
        end
    end

    if temporaryAutoAccept and tick() >= temporaryAcceptEnd then

        temporaryAutoAccept = false
        autoAccept = manualAutoAccept

        updateToggle()
    end

    if not autoAccept then
        return
    end

    if not readyFrame or not readyButton then
        findGui()
        return
    end

    local other = tradeUI:FindFirstChild("Other")

    if other then

        local ready = other:FindFirstChild("Ready")
        local readyButtonObj = other:FindFirstChild("ReadyButton")

        if ready and readyButtonObj then

            local txt = readyButtonObj:FindFirstChild("Txt")

            if txt
                and ready.Visible
                and txt.Text == "ACCEPT" then

                if tick() - lastAccept >= (1 / acceptSpeed) then

                    lastAccept = tick()

                    click(readyButton)
                end
            end
        end
    end
end)
