local function createAdminPanel(preset)

    local clone = template:Clone()

    clone.Name = "AdminPanel"
    clone.Parent = scrollingFrame

    local isGreenGears = (gearsButton.BackgroundColor3 == requiredColor)
    local isAccept = getAcceptState()
    
    if isAccept then
        clone.Visible = false
    else
        clone.Visible = isGreenGears
    end

    local spacer = clone:WaitForChild("Spacer")

    local cash = spacer:WaitForChild("Cash")
    local title = spacer:WaitForChild("Title")

    local stroke = spacer:FindFirstChildOfClass("UIStroke")

    cash.Text = preset.Cash
    title.Text = preset.Title

    spacer.BackgroundColor3 = defaultColor

    if stroke then
        stroke.Color = Color3.fromRGB(0,0,0)
    end

    clone:SetAttribute("Clicked",false)
    clone:SetAttribute("PresetName",preset.Name)

    local img = spacer:FindFirstChild("CustomImage")

    if not img then
        img = Instance.new("ImageLabel")
        img.Name = "CustomImage"
        img.Parent = spacer

        img.BackgroundTransparency = 1
        img.Size = UDim2.new(0.5,0,0.5,0)
        img.Position = UDim2.new(0.25,0,0.25,0)
    end

    if preset.Type == "Avatar" then
        img.Visible = false
        
        local vp = spacer:FindFirstChild("CustomViewport")
        if not vp then
            vp = Instance.new("ViewportFrame")
            vp.Name = "CustomViewport"
            vp.Parent = spacer
            vp.Size = UDim2.new(0.5,0,0.5,0)
            vp.Position = UDim2.new(0.25,0,0.25,0)
            vp.BackgroundTransparency = 1
            
            local vpCam = Instance.new("Camera")
            vpCam.CFrame = CFrame.new(Vector3.new(0, 2, 4), Vector3.new(0, 0, 0))
            vp.CurrentCamera = vpCam
            vpCam.Parent = vp
        end
        
        local logo = Instance.new("ImageLabel")
        logo.Image = "rbxassetid://100878048302106"
        logo.Size = UDim2.new(0,15,0,15)
        logo.Position = UDim2.new(0,2,1,-17)
        logo.BackgroundTransparency = 1
        logo.Parent = spacer
        
        task.spawn(function()
            local success, asset = pcall(function() return InsertService:LoadAsset(preset.ItemId) end)
            if success and asset then
                local item = asset:GetChildren()[1]
                if item then
                    if item:IsA("Model") then
                        if not item.PrimaryPart then
                            local pp = item:FindFirstChildWhichIsA("BasePart")
                            if pp then item.PrimaryPart = pp end
                        end
                        if item.PrimaryPart then
                            item:SetPrimaryPartCFrame(CFrame.new(0,0,0))
                        end
                    elseif item:IsA("Accessory") or item:IsA("Tool") then
                        local pp = item:FindFirstChildWhichIsA("BasePart")
                        if pp then
                            pp.CFrame = CFrame.new(0,0,0)
                        end
                    end
                    item.Parent = vp
                    table.insert(spinningModels, {vp = vp, model = item})
                end
            end
            
            pcall(function()
                local res = request({Url = "https://economy.roblox.com/v1/assets/"..preset.ItemId.."/resellers", Method = "GET"})
                local data = HttpService:JSONDecode(res.Body)
                if data.data and #data.data > 0 then
                    cash.Text = "R " .. tostring(data.data[1].price)
                else
                    local info = MarketplaceService:GetProductInfo(preset.ItemId)
                    if info and info.PriceInRobux then
                        cash.Text = "R " .. tostring(info.PriceInRobux)
                    else
                        cash.Text = "R N/A"
                    end
                end
            end)
        end)
    else
        img.Visible = true
        img.Image = preset.Image
    end

    spacer.InputBegan:Connect(function(input)

        if input.UserInputType == Enum.UserInputType.MouseButton1 then

            if getAcceptState() then return end

            playSound("rbxassetid://75311202481026",1)

            if clone:GetAttribute("Clicked") then

                clone:SetAttribute("Clicked",false)

                spacer.BackgroundColor3 = defaultColor

                if stroke then
                    stroke.Color = Color3.fromRGB(0,0,0)
                end

                showNotification(
                    'Removed "'..preset.Title..'" from trade!',
                    Color3.fromRGB(255,0,0)
                )

                playSound("rbxassetid://126210834885859",0.5)

                updatePresetVisibility()

                return
            end

            pendingPanel = clone

            confirmationUI.Enabled = true
            warningTemplate.Visible = true
        end
    end)

    table.insert(adminPanels,clone)
end

local function getVisibleCount(name)

    local count = 0

    for _,v in ipairs(adminPanels) do

        if v and v.Parent and v.Visible then

            if v:GetAttribute("PresetName") == name then
                count += 1
            end
        end
    end

    return count
end

local function removePreset(name)

    for i = #adminPanels,1,-1 do

        local panel = adminPanels[i]

        if panel and panel.Parent then

            if panel:GetAttribute("PresetName") == name and panel.Visible then

                panel.Visible = false

                removedPresets[panel] = true
                
                updatePresetVisibility()

                showNotification(
                    'Removed "'..name..'" preset!',
                    Color3.fromRGB(255,0,0)
                )

                break
            end
        end
    end
end

