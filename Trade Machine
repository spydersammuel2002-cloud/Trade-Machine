local btnStates = {}

local function setupHoverUpwards(btn)
    local origSize = btn.Size
    local origPos = btn.Position
    btnStates[btn] = {Size = origSize, Position = origPos}

    local hoverSize = UDim2.new(
        origSize.X.Scale * 1.1, origSize.X.Offset * 1.1,
        origSize.Y.Scale * 1.1, origSize.Y.Offset * 1.1
    )

    local hoverPos = UDim2.new(
        origPos.X.Scale - (hoverSize.X.Scale - origSize.X.Scale)/2,
        origPos.X.Offset - (hoverSize.X.Offset - origSize.X.Offset)/2,
        origPos.Y.Scale - (hoverSize.Y.Scale - origSize.Y.Scale),
        origPos.Y.Offset - (hoverSize.Y.Offset - origPos.Y.Offset)
    )

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = hoverSize,
            Position = hoverPos
        }):Play()
    end)

    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = origSize,
            Position = origPos
        }):Play()
    end)
end

local function resetHover(btn)
    if btnStates[btn] then
        TweenService:Create(btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), btnStates[btn]):Play()
    end
end

