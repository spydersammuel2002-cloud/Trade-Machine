local function deletePreset(name)
    for i, p in ipairs(presets) do
        if p.Name == name then
            table.remove(presets, i)
            break
        end
    end
    local savedPresets = {}
    pcall(function()
        if readfile and isfile("t17ed_custom_presets.txt") then
            savedPresets = HttpService:JSONDecode(readfile("t17ed_custom_presets.txt"))
        end
    end)
    for i, p in ipairs(savedPresets) do
        if p.Name == name then
            table.remove(savedPresets, i)
            break
        end
    end
    if writefile then
        writefile("t17ed_custom_presets.txt", HttpService:JSONEncode(savedPresets))
    end
end

