local function showNotification(text,color)

    if notificationCooldown[text] then
        return
    end

    notificationCooldown[text] = true

    task.delay(0.15,function()
        notificationCooldown[text] = nil
    end)

    local clone = notifTemplate:Clone()
    clone.Parent = notificationUI
    clone.Visible = true

    local txt = clone:IsA("TextLabel") and clone or clone:FindFirstChild("Text",true)

    if txt then
        txt.RichText = true
        txt.Text = text
        txt.TextColor3 = color
    end

    local originalPos = clone.Position

    clone.Position = originalPos + UDim2.new(0,300,0,0)

    TweenService:Create(
        clone,
        TweenInfo.new(0.25,Enum.EasingStyle.Quint),
        {
            Position = originalPos
        }
    ):Play()

    task.delay(4,function()

        if clone and clone.Parent then

            TweenService:Create(
                clone,
                TweenInfo.new(0.2),
                {
                    BackgroundTransparency = 1
                }
            ):Play()

            task.wait(0.2)

            if clone then
                clone:Destroy()
            end
        end
    end)
end

local function getAcceptState()

    local other = tradeUI:FindFirstChild("Other")

    if not other then
        return false
    end

    local readyButton = other:FindFirstChild("ReadyButton")

    if not readyButton then
        return false
    end

    local txt = readyButton:FindFirstChild("Txt")

    if not txt then
        return false
    end

    return txt.Text == "ACCEPT"
end

local function updatePresetVisibility()
    local isGreenGears = (gearsButton.BackgroundColor3 == requiredColor)
    local isAccept = getAcceptState()
    
    for _, panel in ipairs(adminPanels) do
        if panel and panel.Parent then
            if removedPresets[panel] then
                panel.Visible = false
            else
                local isClicked = panel:GetAttribute("Clicked") == true
                local isAcceptedVisible = panel:GetAttribute("AcceptedVisible") == true
                
                if isAccept then
                    panel.Visible = isAcceptedVisible
                else
                    if isClicked then
                        panel.Visible = true
                    else
                        panel.Visible = isGreenGears
                    end
                end
            end
        end
    end
end

local function resetPanels()
    local isGreenGears = (gearsButton.BackgroundColor3 == requiredColor)
    local isAccept = getAcceptState()

    for _,panel in ipairs(adminPanels) do
        if panel and panel.Parent then
            if not removedPresets[panel] then
                
                panel:SetAttribute("Clicked",false)
                panel:SetAttribute("AcceptedVisible", false)

                local spacer = panel:FindFirstChild("Spacer")
                if spacer then
                    spacer.BackgroundColor3 = defaultColor
                    local stroke = spacer:FindFirstChildOfClass("UIStroke")
                    if stroke then
                        stroke.Color = Color3.fromRGB(0,0,0)
                    end
                end

                if isAccept then
                    panel.Visible = false
                else
                    panel.Visible = isGreenGears
                end
            else
                panel.Visible = false
            end
        end
    end
end

local function checkAcceptState()
    if getAcceptState() and not acceptProcessed then
        acceptProcessed = true
        for _, panel in ipairs(adminPanels) do
            if panel and panel.Parent then
                if panel:GetAttribute("Clicked") then
                    panel:SetAttribute("AcceptedVisible", true)
                    panel:SetAttribute("Clicked", false)
                    local spacer = panel:FindFirstChild("Spacer")
                    if spacer then
                        spacer.BackgroundColor3 = defaultColor
                        local stroke = spacer:FindFirstChildOfClass("UIStroke")
                        if stroke then
                            stroke.Color = Color3.fromRGB(0,0,0)
                        end
                    end
                else
                    panel:SetAttribute("AcceptedVisible", false)
                end
            end
        end
        updatePresetVisibility()
    end
end

